SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: keep anon key only in frontend if needed
SUPABASE_ANON_KEY=your-anon-key

PORT=4000
RPC_URL=https://rpc.sepolia.org
DEPLOYMENTS_NETWORK=sepolia

# For local demo: RPC_URL=http://127.0.0.1:8545 DEPLOYMENTS_NETWORK=localhost INDEXER_ENABLED=false
# To silence Alchemy 429 rate limits: INDEXER_ENABLED=false or INDEXER_POLL_INTERVAL_MS=60000
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.example
INFURA_SEPOLIA_URL=
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org
FLOW_EVM_TESTNET_RPC=https://testnet.evm.nodes.onflow.org
FLOW_EVM_MAINNET_RPC=https://mainnet.evm.nodes.onflow.org

# Bot protection
TURNSTILE_SECRET_KEY=
TURNSTILE_BYPASS=false
SESSION_TTL_MINUTES=60
NONCE_TTL_MINUTES=10
JSON_BODY_LIMIT=200kb
RATE_LIMIT_MAX=120
RATE_LIMIT_STRICT_MAX=8
RATE_LIMIT_CHAT_MAX=6
RATE_LIMIT_ADMIN_MAX=20
CORS_ORIGINS=
TRUST_PROXY=true
ADMIN_API_KEY=
ADMIN_WALLETS=

# Risk: insider LTV cap (bps, default 1500 = 15%). See docs/FOUNDER_INSIDER_RISK_AND_FLAGGING.md
INSIDER_LTV_BPS=1500
# Risk: max USD exposure per token for concentration cap (optional). See docs/risk/VESTED_TOKEN_LENDING_SESSION_2026-02-14.md
# CONCENTRATION_MAX_USD_PER_TOKEN=500000
# Rate floor (bps, e.g. 700 = 7%, 1000 = 10%). See docs/risk/INTEREST_RATES_AND_POOL_LIFECYCLE.md
# MIN_INTEREST_BPS=700
# Backfill script: node backend/scripts/backfill-loan-token-exposure.js
# BACKFILL_LIMIT=500
# BACKFILL_CHAIN=base

INDEXER_ENABLED=false
INDEXER_LOOKBACK_BLOCKS=2000
INDEXER_POLL_INTERVAL_MS=15000
INDEXER_MAX_EVENTS=200
INDEXER_VESTED_LIMIT=20
INDEXER_SNAPSHOT_INTERVAL_MS=60000
INDEXER_SNAPSHOT_LIMIT=24

# Vestra Premium Privacy (relayer + vault)
EVM_RELAYER_RPC_URL=
EVM_RELAYER_PRIVATE_KEY=
# Optional: used to tag Streamflow positions when recipient is a privacy vault
SOLANA_PRIVACY_VAULT_PUBKEY=

# Data minimization for sensitive tables (SQLite mode)
PRIVACY_PURGE_INTERVAL_MS=3600000
RETENTION_DAYS_AGENT_CONVERSATIONS=14
RETENTION_DAYS_ANALYTICS_EVENTS=30
RETENTION_DAYS_USER_GEO_PRESENCE=7
# Optional: 32-byte key (64 hex chars or base64) to encrypt sensitive SQLite columns.
SENSITIVE_DATA_ENCRYPTION_KEY=
# Gate CSV exports behind admin check (recommended in production).
EXPORTS_ADMIN_ONLY=false
# Optional: comma-separated IPs allowed to export CSVs.
EXPORTS_IP_ALLOWLIST=

# Always-on EVM settlement keeper (calls settleAtUnlock)
EVM_KEEPER_ENABLED=false
EVM_KEEPER_PRIVATE_KEY=
EVM_KEEPER_INTERVAL_MS=60000
EVM_KEEPER_MAX_TX_PER_TICK=4
EVM_KEEPER_RECENT_SCAN=200
EVM_KEEPER_ROTATING_SCAN=200

# Always-on EVM auto-repay keeper (calls repayWithSwapBatchFor for opted-in borrowers)
EVM_REPAY_KEEPER_ENABLED=false
EVM_REPAY_KEEPER_INTERVAL_MS=60000
EVM_REPAY_KEEPER_MAX_TX_PER_TICK=2
EVM_REPAY_KEEPER_LOOKAHEAD_SECONDS=259200
EVM_REPAY_KEEPER_MAX_TOKENS_PER_LOAN=5

# LLM for in-app agent chat (OpenAI-compatible). ASI:One is supported for ASI:Create ecosystem.
ASI_ONE_API_KEY=
# ASI_ONE_BASE_URL=https://api.asi1.ai/v1
# ASI_ONE_MODEL=asi1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Explorer base link override
EXPLORER_BASE_URL=https://sepolia.etherscan.io

# Base-first examples:
# RPC_URL=$BASE_SEPOLIA_RPC DEPLOYMENTS_NETWORK=baseSepolia EXPLORER_BASE_URL=https://sepolia.basescan.org
# RPC_URL=$BASE_MAINNET_RPC DEPLOYMENTS_NETWORK=base EXPLORER_BASE_URL=https://basescan.org
#
# Flow EVM examples:
# RPC_URL=$FLOW_EVM_TESTNET_RPC DEPLOYMENTS_NETWORK=flowEvmTestnet EXPLORER_BASE_URL=https://evm-testnet.flowscan.io
# RPC_URL=$FLOW_EVM_MAINNET_RPC DEPLOYMENTS_NETWORK=flowEvm EXPLORER_BASE_URL=https://evm.flowscan.io

# Solana Streamflow indexing (disable when not using Solana vesting)
SOLANA_STREAMFLOW_ENABLED=false
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet
SOLANA_STREAMFLOW_LIMIT=0
SOLANA_STREAMFLOW_INCLUDE_CLOSED=false
SOLANA_STREAMFLOW_REFRESH_MS=60000
SOLANA_EXPLORER_BASE_URL=https://solscan.io
SOLANA_PYTH_HERMES_URL=https://hermes.pyth.network
SOLANA_PYTH_FEEDS={"So11111111111111111111111111111111111111112":{"symbol":"SOL","feedId":"ef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d"}}
SOLANA_RISK_FREE_RATE=5
SOLANA_VOLATILITY=50
SOLANA_LIQUIDITY_FACTOR=0.9
SOLANA_SHOCK_FACTOR=0.95

# Solana repayment sweep (optional)
SOLANA_REPAY_ENABLED=false
SOLANA_REPAY_CLUSTER=mainnet
SOLANA_REPAY_RPC_URL=
SOLANA_REPAY_AUTHORITY_KEYPAIR=
SOLANA_REPAY_TREASURY=
SOLANA_USDC_MINT=
SOLANA_REPAY_MINTS=
SOLANA_REPAY_MODE=usdc-only
SOLANA_JUPITER_BASE_URL=https://quote-api.jup.ag
SOLANA_JUPITER_SLIPPAGE_BPS=50

# Solana repay job worker (processes queued sweeps)
SOLANA_REPAY_JOBS_ENABLED=false
SOLANA_REPAY_JOBS_INTERVAL_MS=30000
SOLANA_REPAY_JOBS_MAX_PER_TICK=4
ETHERSCAN_API_KEY=

# NIA (Neynar Integration Atlas) for social identity scoring
NIA_API_KEY=
