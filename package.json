{
  "name": "unlockd",
  "version": "1.0.0",
  "description": "UNLOCKD MVP",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n backend,frontend,docs -c green,blue,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\" \"npm run dev --prefix docs-site\"",
    "build": "npm run build --prefix frontend",
    "lint": "eslint .",
    "security:scan": "./scripts/security-scan.sh",
    "test": "npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "test:load": "node scripts/load/run-load-tests.js",
    "deploy:local": "npx hardhat deploy --network hardhat --tags full",
    "deploy:sepolia": "npx hardhat deploy --network sepolia --tags full",
    "deploy:baseSepolia": "npx hardhat deploy --network baseSepolia --tags full",
    "deploy:base": "npx hardhat deploy --network base --tags full",
    "deploy:flowEvmTestnet": "npx hardhat deploy --network flowEvmTestnet --tags full",
    "deploy:flowEvm": "npx hardhat deploy --network flowEvm --tags full",
    "sync:contracts:baseSepolia": "node scripts/sync-frontend-contracts.js --network baseSepolia",
    "sync:contracts:base": "node scripts/sync-frontend-contracts.js --network base",
    "deploy:baseSepolia:sync": "npm run deploy:baseSepolia && npm run sync:contracts:baseSepolia",
    "deploy:base:sync": "npm run deploy:base && npm run sync:contracts:base",
    "check:deploy:baseSepolia": "node scripts/check-deploy-env.js --network baseSepolia",
    "check:deploy:base": "node scripts/check-deploy-env.js --network base",
    "sync:contracts:flowEvmTestnet": "node scripts/sync-frontend-contracts.js --network flowEvmTestnet",
    "sync:contracts:flowEvm": "node scripts/sync-frontend-contracts.js --network flowEvm",
    "sync:contracts:sepolia": "node scripts/sync-frontend-contracts.js --network sepolia",
    "deploy:sepolia:sync": "npm run deploy:sepolia && npm run sync:contracts:sepolia",
    "demo:local": "./scripts/demo-local.sh",
    "dev:local": "DEPLOYMENTS_NETWORK=localhost RPC_URL=http://127.0.0.1:8545 INDEXER_ENABLED=false npm run dev",
    "seed:local": "npx hardhat run scripts/seed-sample-vest.js --network localhost",
    "test:e2e": "npx hardhat run scripts/e2e-local.js --network hardhat",
    "test:e2e:default": "npx hardhat run scripts/e2e-default-local.js --network hardhat",
    "test:e2e:sepolia": "npx hardhat run scripts/e2e-sepolia.js --network sepolia",
    "e2e:sepolia:full": "./scripts/full-sepolia-e2e.sh"
  },
  "keywords": [],
  "author": "",
  "license": "BSL-1.1",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "autocannon": "^8.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "ethers": "^6.16.0",
    "globals": "^17.3.0",
    "hardhat": "^2.22.10",
    "hardhat-deploy": "^0.12.4",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.2.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@uniswap/v3-core": "^1.0.1",
    "@uniswap/v3-periphery": "^1.4.4",
    "@vercel/analytics": "^1.6.1",
    "abdk-libraries-solidity": "^3.0.0",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xkenichi/UNLOCKD.git"
  },
  "bugs": {
    "url": "https://github.com/0xkenichi/UNLOCKD/issues"
  },
  "homepage": "https://github.com/0xkenichi/UNLOCKD#readme"
}
