VITE_BACKEND_URL=http://localhost:4000
VITE_WC_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
VITE_ONRAMPER_API_KEY=
VITE_SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com
VITE_SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# Optional per-chain EVM RPC overrides (defaults come from `frontend/src/utils/chains.js`)
# Flow EVM Testnet (545): https://testnet.evm.nodes.onflow.org
VITE_EVM_RPC_545=
# Flow EVM Mainnet (747): https://mainnet.evm.nodes.onflow.org
VITE_EVM_RPC_747=

# Optional: choose which EVM chain the UI auto-switches to when connected.
# Defaults to Sepolia (11155111). For Flow EVM Testnet use 545.
# VITE_DEFAULT_EVM_CHAIN_ID=545

# Optional feature flags
VITE_FEATURE_SABLIER_IMPORT=true
VITE_FEATURE_FUNDRAISE_ONBOARD=true

# Optional per-chain contract overrides (fallback is `frontend/src/utils/contracts.js`)
# Base mainnet (8453)
VITE_LENDINGPOOL_ADDRESS_8453=
VITE_LOANMANAGER_ADDRESS_8453=
VITE_VALUATIONENGINE_ADDRESS_8453=
VITE_VESTINGADAPTER_ADDRESS_8453=
VITE_TERMVAULT_ADDRESS_8453=
VITE_USDC_ADDRESS_8453=

# Base Sepolia (84532)
VITE_LENDINGPOOL_ADDRESS_84532=
VITE_LOANMANAGER_ADDRESS_84532=
VITE_VALUATIONENGINE_ADDRESS_84532=
VITE_VESTINGADAPTER_ADDRESS_84532=
VITE_TERMVAULT_ADDRESS_84532=
VITE_USDC_ADDRESS_84532=

# Flow EVM Testnet (545)
VITE_LENDINGPOOL_ADDRESS_545=
VITE_LOANMANAGER_ADDRESS_545=
VITE_VALUATIONENGINE_ADDRESS_545=
VITE_VESTINGADAPTER_ADDRESS_545=
VITE_TERMVAULT_ADDRESS_545=
VITE_USDC_ADDRESS_545=

# Flow EVM Mainnet (747)
VITE_LENDINGPOOL_ADDRESS_747=
VITE_LOANMANAGER_ADDRESS_747=
VITE_VALUATIONENGINE_ADDRESS_747=
VITE_VESTINGADAPTER_ADDRESS_747=
VITE_TERMVAULT_ADDRESS_747=
VITE_USDC_ADDRESS_747=

# Alchemy smart wallet rollout (lender onboarding)
VITE_ALCHEMY_ACCOUNT_KIT_APP_ID=
VITE_ALCHEMY_ACCOUNT_KIT_POLICY_ID=
VITE_ALCHEMY_ACCOUNT_KIT_API_KEY=

# Human Passport embed
VITE_PASSPORT_API_KEY=
VITE_PASSPORT_SCORER_ID=
